# Development-only Dockerfile — uses ts-node-dev for hot reload.
# Source code is mounted via volume; no dist/ build needed.
FROM node:18-alpine

WORKDIR /app

# wget needed for health checks
RUN apk add --no-cache wget

# Install dependencies first (cached layer unless package.json changes)
COPY package*.json ./
RUN npm ci

# Source is mounted at runtime via docker-compose volume,
# but copy here as fallback so the image is self-contained.
COPY . .

EXPOSE 4000 3001

# Default command — overridden per-service in docker-compose.dev.yml
CMD ["npm", "run", "start:dev"]
